# Verity Backend Environment Configuration

# Gemini API key used for embeddings (text-embedding-004),
# generation (gemini-2.5-pro), and LLM-as-judge calls.
# Get one at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides for local data persistence
# CHROMA_PERSIST_DIR=./data/chroma_gemini
# BM25_PERSIST_DIR=./data/bm25_gemini
# COLLECTION_NAME=rag_chunks_gemini

# Optional overrides for CORS (default permits localhost Vite)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional overrides for models
# EMBEDDING_MODEL=gemini-embedding-2
# GENERATION_MODEL=gemini-3.1-flash-lite
# JUDGE_MODEL=gemini-3.1-flash-lite
# DEDUP_THRESHOLD=0.95
# RRF_K=60
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
