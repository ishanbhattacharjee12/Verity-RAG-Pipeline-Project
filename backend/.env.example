# --- Required ---
# OpenAI API key used for embeddings (text-embedding-3-small),
# generation (gpt-4o), and LLM-as-judge calls (reranking, citation
# verification, completeness, eval grading).
OPENAI_API_KEY=sk-...

# --- Storage (defaults shown; paths are relative to the backend/ directory) ---
CHROMA_PERSIST_DIR=./data/chroma
BM25_PERSIST_DIR=./data/bm25
DOCUMENTS_DIR=./data/documents

# --- Logging ---
LOG_LEVEL=INFO

# --- Optional overrides ---
# EMBEDDING_MODEL=text-embedding-3-small
# GENERATION_MODEL=gpt-4o
# JUDGE_MODEL=gpt-4o
# DEDUP_THRESHOLD=0.95
# RRF_K=60
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
